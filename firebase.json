{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".github/**",
      "node_modules/**",
      "docs/**",
      "tools/**",
      "concepts/**",
      "backups/**",
      ".codex-temp/**",
      "config.local.js",
      "config.local.example.js",
      "*.zip",
      "*.psd",
      "*.bat",
      "AGENTS.md",
      "README.md"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "cleanUrls": true
  }
}
